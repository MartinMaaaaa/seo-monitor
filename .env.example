# =============================================
# SEO Monitor - Environment Variables Example
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# -----------
# Target site
# -----------
# Base URL of the site to monitor (no trailing slash)
TARGET_SITE_URL=https://subli-star.com

# Path to sitemap (relative to TARGET_SITE_URL, or absolute URL)
SITEMAP_PATH=/sitemap.xml

# -----------
# Crawler
# -----------
# Max concurrent HTTP requests
CRAWLER_CONCURRENCY=5

# Request timeout in seconds
CRAWLER_TIMEOUT=10

# User-Agent string sent with requests
CRAWLER_USER_AGENT=SEO-Monitor/0.1 (+https://subli-star.com)

# -----------
# Storage
# -----------
# Path to SQLite database file (relative to project root)
DATABASE_PATH=data/seo_monitor.db

# -----------
# Notifications (optional, leave blank to disable)
# -----------
# Feishu (Lark) incoming webhook URL
FEISHU_WEBHOOK_URL=

# -----------
# Logging
# -----------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO